---
// "Choose your room" card grid for the booking page, per John's chosen
// design comp: photo, room name, type, price and a see-room link per rate.
// One reservation route per room and rate, never shared across prices.
// All copy arrives from page frontmatter.
import ImageSlot from './ImageSlot.astro';
import type { ImageMetadata } from 'astro';

interface Rate {
  label: string;
  price: string;
  status: 'available' | 'soldout';
  note?: string;
  href?: string;
  cta?: string;
}

interface Room {
  name: string;
  type: string;
  occupancy: string;
  description: string;
  rates: Rate[];
  images: { src?: ImageMetadata; alt: string; shot?: string }[];
}

interface Props {
  rooms: Room[];
}

const { rooms } = Astro.props;

const short = (rate: Rate) =>
  `${rate.price.replace(' per person', '')} / ${rate.label.toLowerCase()} pp`;
---

<section class="rooms-section" id="rooms">
  <div class="container">
    <span class="eyebrow">All-inclusive &middot; From &pound;1,495 pp</span>
    <h2>Choose your room</h2>

    <div class="rooms-grid">
      {
        rooms.map((room) => {
          const available = room.rates.filter((r) => r.status !== 'soldout');
          const primary = available[0] ?? room.rates[0];
          const soldOut = available.length === 0;
          return (
            <article class:list={['room-card', { soldout: soldOut }]}>
              <div class="room-photo">
                <ImageSlot
                  src={room.images[0]?.src}
                  alt={room.images[0]?.alt ?? `The ${room.name} room at the retreat house on Sark`}
                  shot={room.images[0]?.shot ?? `${room.name} room`}
                  width={700}
                  height={470}
                />
              </div>
              <div class="room-body">
                <h3>{room.name}</h3>
                <p class="room-type">{room.type}</p>
                <p class="room-price">
                  {soldOut ? (
                    <span class="price-main">{short(room.rates[0])}</span>
                  ) : (
                    <>
                      <span class="price-main">{short(primary)}</span>
                      {available[1] && <span class="price-alt">{short(available[1])}</span>}
                    </>
                  )}
                </p>
                <p class="room-links">
                  {soldOut ? (
                    <span class="room-soldout">Sold out</span>
                  ) : (
                    available.map((rate) => (
                      <a class="room-link" href={rate.href}>
                        {available.length > 1 ? `${rate.label} room` : 'See room'} &rarr;
                      </a>
                    ))
                  )}
                </p>
                {!soldOut && room.rates.some((r) => r.status === 'soldout') && (
                  <p class="room-note muted">Single occupancy sold out</p>
                )}
                {primary?.note && !soldOut && <p class="room-note">{primary.note}</p>}
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .rooms-section {
    padding-bottom: var(--space-section);
    text-align: center;
  }

  .rooms-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 36px;
    text-align: left;
  }

  @media (min-width: 640px) {
    .rooms-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1000px) {
    .rooms-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .room-card {
    background: #fff;
    border: 1px solid var(--cream-deep);
  }

  .room-card.soldout {
    opacity: 0.75;
  }

  .room-photo :global(picture) {
    display: block;
  }

  .room-photo :global(img),
  .room-photo :global(.image-slot) {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .room-body {
    padding: 22px 24px 26px;
  }

  .room-body h3 {
    font-size: 26px;
    margin-bottom: 2px;
  }

  .room-type {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--sage-dark);
    margin-bottom: 18px;
  }

  .room-price {
    margin-bottom: 18px;
    display: grid;
    gap: 2px;
  }

  .price-main {
    font-family: var(--font-display);
    font-size: 24px;
    color: var(--clay);
  }

  .price-alt {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--sage-dark);
  }

  .room-links {
    margin: 0;
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }

  .room-link {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--clay-dark);
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .room-link:hover {
    color: var(--clay);
  }

  /* Status badges read at scroll speed, per Nadia: sold out is a filled
     quiet badge, one space left is a clay pill that catches the eye
     without shouting. */
  .room-soldout {
    display: inline-block;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    background: var(--sage-dark);
    padding: 10px 18px;
  }

  .room-note {
    display: inline-block;
    margin: 14px 0 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
    background: var(--clay);
    padding: 6px 14px;
    border-radius: 2px;
  }

  .room-note.muted {
    background: transparent;
    padding: 0;
    color: var(--sage);
  }
</style>
