---
// House tour features as a two column grid, per John's chosen design:
// photo on top, heading and a short line beneath. Copy arrives from page
// frontmatter, never hard-coded here.
import ImageSlot from './ImageSlot.astro';
import type { ImageMetadata } from 'astro';

interface Feature {
  heading: string;
  body: string;
  image?: ImageMetadata;
  alt: string;
  shot: string;
}

interface Props {
  features: Feature[];
  eyebrow?: string;
}

const { features, eyebrow = 'Your home for the week' } = Astro.props;
---

<section class="features section">
  <div class="container">
    <span class="eyebrow features-eyebrow">{eyebrow}</span>
    <div class="features-grid">
      {
        features.map((f) => (
          <div class="feature">
            <div class="feature-photo">
              <ImageSlot
                src={f.image}
                alt={f.alt || f.heading}
                shot={f.shot || f.heading}
                width={880}
                height={620}
              />
            </div>
            <h3>{f.heading}</h3>
            <p>{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    background: #fff;
  }

  .features-eyebrow {
    text-align: center;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(36px, 5vw, 56px) clamp(24px, 3vw, 40px);
    margin-top: 28px;
  }

  @media (min-width: 760px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .feature-photo :global(picture) {
    display: block;
  }

  .feature-photo :global(img),
  .feature-photo :global(.image-slot) {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .feature h3 {
    font-size: 24px;
    margin: 18px 0 4px;
  }

  .feature p {
    font-size: 15px;
    margin: 0;
    max-width: none;
  }
</style>
