---
// Cream strip, italic Cormorant quote, fixed attribution. The leaf is Nadia's alone.
interface Props {
  quote: string;
}

const { quote } = Astro.props;
---

<section class="nadia-note">
  <div class="narrow">
    <blockquote>
      <p>{quote}</p>
      <cite>Nadia · Founder &amp; Host · Sark Soul Island Retreats 🌿</cite>
    </blockquote>
  </div>
</section>

<style>
  .nadia-note {
    background: var(--cream);
    border-top: 1px solid var(--cream-deep);
    border-bottom: 1px solid var(--cream-deep);
    padding-block: clamp(48px, 7vw, 80px);
    text-align: center;
  }

  blockquote {
    margin: 0;
  }

  blockquote p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 3vw, 30px);
    line-height: 1.4;
    color: var(--ink);
    margin: 0 auto 22px;
    max-width: 34ch;
  }

  cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--sage-dark);
  }
</style>
