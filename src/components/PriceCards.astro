---
// Three cards, featured card gets a teal border. Amounts in Cormorant 44px.
// Pricing is fixed by the guardrails; £1,495 is correct, not an error.
const cards = [
  {
    name: 'Shared room',
    label: 'Early booking',
    price: '£1,495',
    note: 'Early rate ends 19 July 2026',
    featured: true,
  },
  {
    name: 'Shared room',
    label: 'Standard',
    price: '£1,695',
    note: 'Full flexibility, same retreat',
    featured: false,
  },
  {
    name: 'Single room',
    label: 'Early booking',
    price: '£1,995',
    note: 'A room of your own for the week',
    featured: false,
  },
];
---

<section class="price-cards">
  <div class="container">
    <span class="eyebrow">Late Summer Retreat · 12 to 17 September 2026</span>
    <h2>What does the retreat cost?</h2>
    <div class="cards">
      {
        cards.map((card) => (
          <article class:list={['card', { featured: card.featured }]}>
            <span class="card-label">{card.label}</span>
            <h3>{card.name}</h3>
            <p class="amount">{card.price}</p>
            <p class="note">{card.note}</p>
            <a class="btn" href="/retreats-on-sark">
              Reserve my place
            </a>
          </article>
        ))
      }
    </div>
    <p class="fine">
      Five nights at our historic farmhouse, all yoga sessions, and every meal included.
    </p>
  </div>
</section>

<style>
  .price-cards {
    background: var(--cream);
    padding-block: clamp(64px, 10vw, 110px);
    text-align: center;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  @media (min-width: 768px) {
    .cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .card {
    background: var(--paper);
    border: 1px solid var(--cream-deep);
    padding: 40px 28px 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .card.featured {
    border: 2px solid var(--teal);
  }

  .card-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sage);
  }

  .card h3 {
    margin: 10px 0 0;
  }

  .amount {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 500;
    color: var(--ink);
    margin: 6px 0 2px;
  }

  .note {
    font-size: 14px;
    color: var(--sage-dark);
    margin-bottom: 22px;
  }

  .card .btn {
    margin-top: auto;
  }

  .fine {
    margin: 36px auto 0;
    font-size: 14px;
    color: var(--sage-dark);
  }
</style>
