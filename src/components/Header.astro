---
// Site-wide navigation, styled after the live site's master header: centred
// small caps links with the full logo lockup closing the row. The five
// intent pages are reached through the Retreats dropdown and internal links.
import { Image } from 'astro:assets';
import logo from '../assets/sark-soul-island-retreats-logo.png';

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Our Retreats', href: '/retreats-on-sark', dropdown: true },
  { label: 'Why Sark?', href: '/why-sark' },
  { label: 'The Practice', href: '/the-practice' },
  { label: 'Our Story', href: '/our-story' },
  { label: 'Meet the Team', href: '/meet-the-team' },
];

const retreats = [
  { label: 'Retreats & Booking', href: '/retreats-on-sark' },
  { label: 'Yoga Retreat on Sark', href: '/yoga-retreat-sark' },
  { label: 'Digital Detox Retreat', href: '/digital-detox-retreat' },
  { label: 'Solo Retreat for Women', href: '/solo-retreat-women' },
  { label: 'Burnout Retreat', href: '/burnout-retreat' },
  { label: 'Dark Sky Retreat', href: '/dark-sky-retreat' },
];

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Open menu">
      <span></span><span></span><span></span>
    </label>
    <nav aria-label="Main">
      <ul>
        {
          nav.map((item) =>
            item.dropdown ? (
              <li class="has-dropdown">
                <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
                  {item.label}
                </a>
                <ul class="dropdown">
                  {retreats.map((r) => (
                    <li>
                      <a href={r.href}>{r.label}</a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>
    <a class="brand" href="/" aria-label="Sark Soul Island Retreats, home">
      <Image src={logo} alt="Sark Soul Island Retreats" width={140} height={163} loading="eager" class="brand-logo" />
    </a>
  </div>
</header>

<style>
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--cream-deep);
    position: relative;
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 34px;
    padding-block: 14px;
  }

  nav > ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 30px;
    margin: 0;
    padding: 0;
  }

  nav a {
    font-family: var(--font-display);
    font-variant: small-caps;
    font-size: 19px;
    font-weight: 500;
    letter-spacing: 1.2px;
    color: var(--ink-soft);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--teal-dark);
  }

  nav a[aria-current='page'] {
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
  }

  .brand {
    display: block;
    line-height: 0;
  }

  .brand :global(.brand-logo) {
    width: 70px;
    height: 82px;
  }

  .has-dropdown {
    position: relative;
  }

  .dropdown {
    display: none;
    list-style: none;
    margin: 0;
    position: absolute;
    top: 100%;
    left: -18px;
    background: var(--paper);
    border: 1px solid var(--cream-deep);
    padding: 10px 0;
    min-width: 230px;
    box-shadow: 0 12px 30px rgba(21, 33, 46, 0.08);
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }

  .dropdown a {
    display: block;
    padding: 8px 18px;
    font-family: var(--font-body);
    font-variant: normal;
    letter-spacing: 0.3px;
    font-size: 14px;
    font-weight: 400;
  }

  .nav-toggle,
  .nav-toggle-label {
    display: none;
  }

  @media (max-width: 900px) {
    .header-inner {
      justify-content: space-between;
      flex-wrap: wrap;
    }

    .nav-toggle-label {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px 0;
      order: 1;
    }

    .nav-toggle-label span {
      width: 24px;
      height: 1.5px;
      background: var(--ink);
    }

    .brand {
      order: 2;
    }

    .brand :global(.brand-logo) {
      width: 56px;
      height: 66px;
    }

    nav {
      display: none;
      width: 100%;
      order: 3;
    }

    .nav-toggle:checked ~ nav {
      display: block;
    }

    nav > ul {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding-block: 12px 20px;
    }

    .dropdown {
      display: block;
      position: static;
      border: none;
      box-shadow: none;
      background: transparent;
      padding: 8px 0 0 16px;
    }
  }
</style>
