---
// Site-wide navigation with the logo centred, per Nadia: small caps links
// split either side of the full logo lockup. The five intent pages are
// reached through the Retreats dropdown and internal links.
import { Image } from 'astro:assets';
import logo from '../assets/sark-soul-island-retreats-logo.png';

const navLeft = [
  { label: 'Home', href: '/' },
  { label: 'The Retreat Experience', href: '/retreats-on-sark', dropdown: true },
  { label: 'Why Sark?', href: '/why-sark' },
];

const navRight = [
  { label: 'The Practice', href: '/the-practice' },
  { label: 'Our Story', href: '/our-story' },
  { label: 'The Journal', href: '/journal' },
];

// Facets of the one September retreat, not separate retreats. Labels must
// read that way, per Nadia; the pages themselves are search doorways.
const retreats = [
  { label: 'Retreats & Booking', href: '/retreats-on-sark' },
  { label: 'The Yoga', href: '/yoga-retreat-sark' },
  { label: 'A Digital Detox', href: '/digital-detox-retreat' },
  { label: 'Travelling Solo', href: '/solo-retreat-women' },
  { label: 'Rest & Recovery', href: '/burnout-retreat' },
  { label: 'The Dark Skies', href: '/dark-sky-retreat' },
];

const current = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
---

<header class="site-header">
  <div class="container header-inner">
    <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Open menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav-left" aria-label="Main">
      <ul>
        {
          navLeft.map((item) =>
            item.dropdown ? (
              <li class="has-dropdown">
                <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
                  {item.label}
                </a>
                <ul class="dropdown">
                  {retreats.map((r) => (
                    <li>
                      <a href={r.href}>{r.label}</a>
                    </li>
                  ))}
                </ul>
              </li>
            ) : (
              <li>
                <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>

    <a class="brand" href="/" aria-label="Sark Soul Island Retreats, home">
      <Image src={logo} alt="Sark Soul Island Retreats" width={140} height={163} loading="eager" fetchpriority="low" class="brand-logo" />
    </a>

    <nav class="nav-right" aria-label="More">
      <ul>
        {
          navRight.map((item) => (
            <li>
              <a href={item.href} aria-current={current === item.href ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid var(--cream-deep);
    position: relative;
    z-index: 50;
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 34px;
    padding-block: 14px;
  }

  nav > ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 30px;
    margin: 0;
    padding: 0;
  }

  .nav-left > ul {
    justify-content: flex-end;
  }

  .nav-right > ul {
    justify-content: flex-start;
  }

  nav a {
    font-family: var(--font-display);
    font-variant: small-caps;
    font-size: 19px;
    font-weight: 500;
    letter-spacing: 1.2px;
    color: var(--ink-soft);
    text-decoration: none;
    white-space: nowrap;
  }

  nav a:hover {
    color: var(--teal-dark);
  }

  nav a[aria-current='page'] {
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 1px;
  }

  .brand {
    display: block;
    line-height: 0;
    justify-self: center;
  }

  .brand :global(.brand-logo) {
    width: 70px;
    height: 82px;
  }

  .has-dropdown {
    position: relative;
  }

  .dropdown {
    display: none;
    list-style: none;
    margin: 0;
    position: absolute;
    top: 100%;
    left: -18px;
    background: #fff;
    border: 1px solid var(--cream-deep);
    padding: 10px 0;
    min-width: 230px;
    box-shadow: 0 12px 30px rgba(21, 33, 46, 0.08);
    z-index: 60;
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: block;
  }

  .dropdown a {
    display: block;
    padding: 8px 18px;
    font-family: var(--font-body);
    font-variant: normal;
    letter-spacing: 0.3px;
    font-size: 14px;
    font-weight: 400;
    white-space: nowrap;
  }

  .nav-toggle,
  .nav-toggle-label {
    display: none;
  }

  @media (max-width: 900px) {
    .header-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }

    /* Invisible spacer the same width as the hamburger, so the logo sits
       dead centre between them, per Nadia's UAT: central on mobile too. */
    .header-inner::after {
      content: '';
      width: 24px;
      order: 2;
    }

    .nav-toggle-label {
      display: flex;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 8px 0;
      order: 1;
    }

    .nav-toggle-label span {
      width: 24px;
      height: 1.5px;
      background: var(--ink);
    }

    .brand {
      order: 2;
    }

    .brand :global(.brand-logo) {
      width: 56px;
      height: 66px;
    }

    .nav-left,
    .nav-right {
      display: none;
      width: 100%;
      order: 3;
    }

    .nav-toggle:checked ~ .nav-left,
    .nav-toggle:checked ~ .nav-right {
      display: block;
    }

    .nav-right {
      order: 4;
    }

    .nav-left > ul,
    .nav-right > ul {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 16px;
      padding-block: 12px 4px;
    }

    .dropdown {
      display: block;
      position: static;
      border: none;
      box-shadow: none;
      background: transparent;
      padding: 8px 0 0 16px;
    }
  }
</style>
