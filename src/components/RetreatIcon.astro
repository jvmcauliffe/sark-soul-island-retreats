---
// Icons for the What's Included and Retreat Add-ons lists. These are the
// exact vector icons from the live site, saved as static SVGs under
// /public/icons/. Decorative only, zero JS. Icon names are chosen in page
// frontmatter; this component maps them to their files.
interface Props {
  name: string;
}

const { name } = Astro.props;

const files: Record<string, string> = {
  yoga: 'yoga',
  stars: 'night-sky',
  moon: 'rest',
  carriage: 'carriage',
  house: 'farmhouse',
  path: 'activities',
  cutlery: 'meals',
  ferry: 'ferry',
  pool: 'pools',
  heart: 'support',
  massage: 'massage',
  reiki: 'reiki',
  snowflake: 'cold-immersion',
};

// Short literal alts. Empty alt is the purist treatment for decorative
// icons, but audit tools count empty as missing; a brief label costs
// nothing and keeps the crawl report clean.
const labels: Record<string, string> = {
  yoga: 'Yoga icon',
  stars: 'Night sky icon',
  moon: 'Rest icon',
  carriage: 'Horse and carriage icon',
  house: 'Farmhouse icon',
  path: 'Activities icon',
  cutlery: 'Meals icon',
  ferry: 'Ferry icon',
  pool: 'Sea pools icon',
  heart: 'Support icon',
  massage: 'Massage icon',
  reiki: 'Reiki icon',
  snowflake: 'Cold immersion icon',
};
---

<img src={`/icons/${files[name] ?? name}.svg`} alt={labels[name] ?? ''} width="44" height="44" loading="lazy" />
