---
// Icons for the What's Included and Retreat Add-ons lists. These are the
// exact vector icons from the live site, saved as static SVGs under
// /public/icons/. Decorative only, zero JS. Icon names are chosen in page
// frontmatter; this component maps them to their files.
interface Props {
  name: string;
}

const { name } = Astro.props;

const files: Record<string, string> = {
  yoga: 'yoga',
  stars: 'night-sky',
  moon: 'rest',
  carriage: 'carriage',
  house: 'farmhouse',
  path: 'activities',
  cutlery: 'meals',
  ferry: 'ferry',
  pool: 'pools',
  heart: 'support',
  massage: 'massage',
  reiki: 'reiki',
  snowflake: 'cold-immersion',
};
---

<img src={`/icons/${files[name] ?? name}.svg`} alt="" width="44" height="44" loading="lazy" />
