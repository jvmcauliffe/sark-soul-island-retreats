---
// Real photography only. Until John supplies photos, this renders a neutral
// gradient placeholder with a visible caption naming the required shot.
// When a photo exists in /src/assets/photos/, pass it via `src` and the slot
// switches to Astro's optimized Picture output (AVIF with WebP fallback).
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src?: ImageMetadata;
  alt: string;
  shot: string;
  width?: number;
  height?: number;
  priority?: boolean;
  class?: string;
}

const { src, alt, shot, width = 1200, height = 800, priority = false, class: className = '' } = Astro.props;
---

{
  src ? (
    <Picture
      src={src}
      alt={alt}
      width={width}
      height={height}
      formats={['avif', 'webp']}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      class={`image-slot ${className}`}
    />
  ) : (
    <div
      class={`image-slot placeholder ${className}`}
      style={`aspect-ratio: ${width} / ${height};`}
      role="img"
      aria-label={alt}
    >
      <span class="shot-label">Photo needed: {shot}</span>
    </div>
  )
}

<style>
  .image-slot {
    width: 100%;
    object-fit: cover;
  }

  .placeholder {
    background: linear-gradient(160deg, var(--cream) 0%, var(--cream-deep) 55%, #d8ccb4 100%);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 18px;
  }

  .shot-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--sage-dark);
    background: rgba(251, 248, 241, 0.85);
    padding: 6px 12px;
  }
</style>
