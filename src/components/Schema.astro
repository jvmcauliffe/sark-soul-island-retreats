---
// Sitewide JSON-LD graph. Founder attribution at schema level is a deliberate
// fix for a live Google AI Overview misattribution: Nadia is founder, Monica
// is a senior yoga teacher only.
interface Offer {
  name: string;
  price: string;
  validThrough?: string;
}

interface Props {
  canonical: string;
  event?: boolean;
  eventYear?: '2026' | '2027';
  article?: {
    headline: string;
    description: string;
    datePublished: string;
    author: string;
  };
}

// September 2026 is postponed and quietly withdrawn from sale, per John,
// 19 July 2026. Every event page now describes the 2027 retreat.
const { canonical, event = false, eventYear = '2027', article } = Astro.props;

const site = 'https://www.sarksoulretreats.com';

const nadia = {
  '@type': 'Person',
  '@id': `${site}/#nadia`,
  name: 'Nadia',
  description: 'Founder and host of Sark Soul Island Retreats',
  jobTitle: 'Founder & Host',
  worksFor: { '@id': `${site}/#business` },
};

const monica = {
  '@type': 'Person',
  '@id': `${site}/#monica`,
  name: 'Monica',
  jobTitle: 'Senior Yoga Teacher',
  worksFor: { '@id': `${site}/#business` },
};

const business = {
  '@type': 'LocalBusiness',
  '@id': `${site}/#business`,
  name: 'Sark Soul Island Retreats',
  url: site,
  telephone: '+44 7444133015',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Isle of Sark',
    addressRegion: 'Channel Islands',
  },
  // Entity links: tie the brand to its official profiles so Google's
  // knowledge panel consolidates around this business, not lookalikes.
  sameAs: [
    'https://g.page/r/CdhrtAEddmE_EBM/review',
    'https://www.instagram.com/sarksoulretreats',
    'https://www.facebook.com/people/Sark-Soul-Island-Retreats/61577714589614/',
  ],
  founder: { '@id': `${site}/#nadia` },
  employee: [{ '@id': `${site}/#nadia` }, { '@id': `${site}/#monica` }],
};

// One entry per retreat. The 2026 event was removed when September 2026
// was postponed; 2027 is the only retreat on sale.
const retreats = {
  '2027': {
    name: 'Sark Soul Island Retreats, September Retreat 2027',
    description:
      'A five-night small-group yoga and wellness retreat on the Isle of Sark, the world’s first Dark Sky Island. Daily yoga with senior teacher Monica, coastal walks, wild swimming and vegetarian meals at a historic farmhouse.',
    startDate: '2027-09-25',
    endDate: '2027-09-30',
    url: `${site}/retreats-on-sark`,
    // Monica confirmed for September 2027, per John, 18 July 2026.
    performer: { '@id': `${site}/#monica` },
    offers: [
      { name: 'Shared room, early booking', price: '1495' },
      { name: 'Single room', price: '1995' },
    ] as Offer[],
  },
};

const retreat = retreats['2027'];

const eventNode = event
  ? {
      '@type': 'Event',
      name: retreat.name,
      description: retreat.description,
      image: [`${site}/og-default.jpg`],
      startDate: retreat.startDate,
      endDate: retreat.endDate,
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      eventStatus: 'https://schema.org/EventScheduled',
      location: {
        '@type': 'Place',
        name: 'Isle of Sark',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Isle of Sark',
          addressRegion: 'Channel Islands',
        },
      },
      organizer: { '@id': `${site}/#business` },
      ...(retreat.performer ? { performer: retreat.performer } : {}),
      offers: retreat.offers.map((o) => ({
        '@type': 'Offer',
        name: o.name,
        price: o.price,
        priceCurrency: 'GBP',
        url: retreat.url,
        availability: 'https://schema.org/InStock',
        ...(o.validThrough ? { validThrough: o.validThrough } : {}),
      })),
    }
  : null;

const articleNode = article
  ? {
      '@type': 'Article',
      headline: article.headline,
      description: article.description,
      datePublished: article.datePublished,
      mainEntityOfPage: canonical,
      author:
        article.author === 'Nadia'
          ? { '@id': `${site}/#nadia` }
          : { '@type': 'Person', name: article.author },
      publisher: { '@id': `${site}/#business` },
    }
  : null;

const graph = {
  '@context': 'https://schema.org',
  '@graph': [business, nadia, monica, eventNode, articleNode].filter(Boolean),
};
---

<script type="application/ld+json" set:html={JSON.stringify(graph)} />
