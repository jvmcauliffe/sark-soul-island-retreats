---
// Full-bleed photo hero with bottom-weighted gradient scrim.
// H1 is real text, never baked into the image.
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow: string;
  title: string;
  brand?: boolean;
  centered?: boolean;
  cta?: boolean;
  sub?: string;
  note?: string;
  line: string;
  ctaLabel?: string;
  ctaHref?: string;
  image?: ImageMetadata;
  imageAlt: string;
  shot: string;
  focus?: string;
}

const {
  eyebrow,
  title,
  brand = false,
  centered = false,
  cta = true,
  sub,
  note,
  line,
  ctaLabel = 'Reserve my place',
  ctaHref = '/retreats-on-sark',
  image,
  imageAlt,
  shot,
  focus,
} = Astro.props;
---

<section class="hero on-dark">
  {
    image ? (
      <Picture
        src={image}
        alt={imageAlt}
        widths={[480, 800, 1200, 1800]}
        sizes="100vw"
        formats={['avif', 'webp']}
        quality={70}
        loading="eager"
        fetchpriority="high"
        class="hero-image"
        style={focus ? `object-position: ${focus}` : undefined}
      />
    ) : (
      <div class="hero-image hero-placeholder" role="img" aria-label={imageAlt}>
        <span class="shot-label">Photo needed: {shot}</span>
      </div>
    )
  }
  <div class="scrim" aria-hidden="true"></div>
  <div class:list={['hero-content', 'container', { centered }]}>
    {eyebrow && <span class="eyebrow gold">{eyebrow}</span>}
    {brand && <p class="brand-display" aria-hidden="true">Sark Soul Island Retreats</p>}
    <h1 class:list={{ 'with-brand': brand }}>{title}</h1>
    {sub && <p class="hero-sub">{sub}</p>}
    {line && <p class="hero-line">{line}</p>}
    {note && <p class="hero-note">{note}</p>}
    {cta && <a class="btn" href={ctaHref}>{ctaLabel}</a>}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(82vh, 720px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-placeholder {
    background:
      radial-gradient(ellipse at 70% 20%, #33465c 0%, transparent 60%),
      linear-gradient(170deg, #243443 0%, #15212e 70%);
  }

  .shot-label {
    position: absolute;
    top: 18px;
    right: 18px;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--cream);
    background: rgba(21, 33, 46, 0.6);
    padding: 6px 12px;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17, 27, 39, 0.82) 0%, rgba(17, 27, 39, 0.35) 40%, rgba(17, 27, 39, 0.05) 75%);
  }

  .hero-content {
    position: relative;
    padding-block: clamp(56px, 9vw, 110px);
  }

  .hero h1 {
    color: #fff;
    max-width: 15ch;
    margin-bottom: 0.35em;
  }

  .brand-display {
    font-family: var(--font-display);
    font-size: clamp(40px, 6.4vw, 72px);
    font-weight: 500;
    line-height: 1.08;
    color: #fff;
    max-width: 12ch;
    margin: 0 0 0.2em;
  }

  .hero h1.with-brand {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.8vw, 21px);
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cream);
    max-width: none;
    margin-bottom: 0.6em;
  }

  .hero p {
    color: var(--cream);
    font-size: 19px;
    max-width: 46ch;
    margin-bottom: 1.8em;
  }

  /* Centered white hero, live site treatment */
  .hero-content.centered {
    text-align: center;
    align-self: center;
    padding-block: clamp(72px, 12vw, 150px);
  }

  .hero-content.centered h1 {
    max-width: none;
    margin-inline: auto;
    font-size: clamp(42px, 6.6vw, 74px);
  }

  .hero-content.centered .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.6vw, 30px);
    color: #fff;
    max-width: none;
    margin: 0 auto 1.4em;
  }

  .hero-content.centered .hero-line {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1.5px;
    max-width: none;
    margin: 0 auto 0.9em;
    color: #fff;
  }

  .hero-content.centered .hero-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    max-width: none;
    margin: 0 auto 1.6em;
    color: #fff;
  }
</style>
