---
// Full-bleed photo hero with bottom-weighted gradient scrim.
// H1 is real text, never baked into the image.
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow: string;
  title: string;
  line: string;
  ctaLabel?: string;
  ctaHref?: string;
  image?: ImageMetadata;
  imageAlt: string;
  shot: string;
}

const {
  eyebrow,
  title,
  line,
  ctaLabel = 'Reserve my place',
  ctaHref = '/retreats-on-sark',
  image,
  imageAlt,
  shot,
} = Astro.props;
---

<section class="hero on-dark">
  {
    image ? (
      <Picture
        src={image}
        alt={imageAlt}
        widths={[480, 800, 1200, 1800]}
        sizes="100vw"
        formats={['avif', 'webp']}
        quality={70}
        loading="eager"
        fetchpriority="high"
        class="hero-image"
      />
    ) : (
      <div class="hero-image hero-placeholder" role="img" aria-label={imageAlt}>
        <span class="shot-label">Photo needed: {shot}</span>
      </div>
    )
  }
  <div class="scrim" aria-hidden="true"></div>
  <div class="hero-content container">
    <span class="eyebrow gold">{eyebrow}</span>
    <h1>{title}</h1>
    <p>{line}</p>
    <a class="btn" href={ctaHref}>{ctaLabel}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(82vh, 720px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-placeholder {
    background:
      radial-gradient(ellipse at 70% 20%, #33465c 0%, transparent 60%),
      linear-gradient(170deg, #243443 0%, #15212e 70%);
  }

  .shot-label {
    position: absolute;
    top: 18px;
    right: 18px;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--cream);
    background: rgba(21, 33, 46, 0.6);
    padding: 6px 12px;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17, 27, 39, 0.82) 0%, rgba(17, 27, 39, 0.35) 40%, rgba(17, 27, 39, 0.05) 75%);
  }

  .hero-content {
    position: relative;
    padding-block: clamp(56px, 9vw, 110px);
  }

  .hero h1 {
    color: #fff;
    max-width: 15ch;
    margin-bottom: 0.35em;
  }

  .hero p {
    color: var(--cream);
    font-size: 19px;
    max-width: 46ch;
    margin-bottom: 1.8em;
  }
</style>
