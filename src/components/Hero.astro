---
// Full-bleed photo hero with bottom-weighted gradient scrim.
// H1 is real text, never baked into the image.
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow: string;
  title: string;
  brand?: boolean;
  centered?: boolean;
  cta?: boolean;
  sub?: string;
  note?: string;
  line: string;
  ctaLabel?: string;
  ctaHref?: string;
  image?: ImageMetadata;
  imageAlt: string;
  shot: string;
  focus?: string;
  focusMobile?: string;
  tall?: boolean;
}

const {
  eyebrow,
  title,
  brand = false,
  centered = false,
  cta = true,
  sub,
  note,
  line,
  ctaLabel = 'Reserve my place',
  ctaHref = '/retreats-on-sark',
  image,
  imageAlt,
  shot,
  focus,
  focusMobile,
  tall = false,
} = Astro.props;

// Crop control travels as CSS custom properties rather than a hard inline
// object-position, so the mobile crop can differ from desktop. Landscape
// photos lose their edges on a tall phone crop; focusMobile picks which
// part of the frame survives.
const focusStyle =
  [focus ? `--focus: ${focus}` : '', focusMobile ? `--focus-mobile: ${focusMobile}` : '']
    .filter(Boolean)
    .join('; ') || undefined;
---

<section class:list={['hero', 'on-dark', { 'hero-tall': tall }]}>
  {
    image ? (
      <Picture
        src={image}
        alt={imageAlt}
        widths={[480, 800, 1200, 1800]}
        sizes="100vw"
        formats={['avif', 'webp']}
        quality={70}
        loading="eager"
        fetchpriority="high"
        class="hero-image"
        style={focusStyle}
      />
    ) : (
      <div class="hero-image hero-placeholder" role="img" aria-label={imageAlt}>
        <span class="shot-label">Photo needed: {shot}</span>
      </div>
    )
  }
  <div class="scrim" aria-hidden="true"></div>
  <div class:list={['hero-content', 'container', { centered }]}>
    {eyebrow && <span class="eyebrow gold">{eyebrow}</span>}
    {brand && <p class="brand-display" aria-hidden="true">Sark Soul Island Retreats</p>}
    <h1 class:list={{ 'with-brand': brand }}>{title}</h1>
    {sub && <p class="hero-sub">{sub}</p>}
    {line && <p class="hero-line">{line}</p>}
    {note && <p class="hero-note">{note}</p>}
    {cta && <a class="btn" href={ctaHref}>{ctaLabel}</a>}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(82vh, 720px);
  }

  /* Taller variant for portrait hero photos that need more of the frame */
  .hero.hero-tall {
    min-height: min(96vh, 960px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--focus, 50% 50%);
  }

  .hero-placeholder {
    background:
      radial-gradient(ellipse at 70% 20%, #33465c 0%, transparent 60%),
      linear-gradient(170deg, #243443 0%, #15212e 70%);
  }

  .shot-label {
    position: absolute;
    top: 18px;
    right: 18px;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--cream);
    background: rgba(21, 33, 46, 0.6);
    padding: 6px 12px;
  }

  .scrim {
    /* Lighter than it was: Nadia read the old bottom half as a dark filter
       over the photo. The text shadows carry legibility now, so the photo
       keeps its true colour. */
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17, 27, 39, 0.62) 0%, rgba(17, 27, 39, 0.24) 42%, rgba(17, 27, 39, 0.03) 75%);
  }

  .hero-content {
    position: relative;
    padding-block: clamp(56px, 9vw, 110px);
  }

  .hero h1 {
    color: #fff;
    max-width: 15ch;
    margin-bottom: 0.35em;
    text-shadow: 0 2px 22px rgba(17, 27, 39, 0.55), 0 1px 3px rgba(17, 27, 39, 0.4);
  }

  .brand-display {
    font-family: var(--font-display);
    font-size: clamp(40px, 6.4vw, 72px);
    font-weight: 500;
    line-height: 1.08;
    color: #fff;
    max-width: 12ch;
    margin: 0 0 0.2em;
    /* Per Nadia's UAT: the brand name must stand out from the photo, not
       sink into it. Soft wide shadow plus a tight one for edge definition. */
    text-shadow: 0 2px 26px rgba(17, 27, 39, 0.6), 0 1px 4px rgba(17, 27, 39, 0.45);
  }

  .hero h1.with-brand {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.8vw, 21px);
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cream);
    max-width: none;
    margin-bottom: 0.6em;
    text-shadow: 0 1px 14px rgba(17, 27, 39, 0.55);
  }

  .hero p {
    color: var(--cream);
    font-size: 19px;
    max-width: 46ch;
    margin-bottom: 1.8em;
    text-shadow: 0 1px 12px rgba(17, 27, 39, 0.5);
  }

  /* Centered white hero, live site treatment */
  .hero-content.centered {
    text-align: center;
    align-self: center;
    padding-block: clamp(72px, 12vw, 150px);
  }

  .hero-content.centered h1 {
    max-width: none;
    margin-inline: auto;
    font-size: clamp(42px, 6.6vw, 74px);
  }

  .hero-content.centered .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.6vw, 30px);
    color: #fff;
    max-width: none;
    margin: 0 auto 1.4em;
  }

  .hero-content.centered .hero-line {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 1.5px;
    max-width: none;
    margin: 0 auto 0.9em;
    color: #fff;
  }

  .hero-content.centered .hero-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    max-width: none;
    margin: 0 auto 1.6em;
    color: #fff;
  }

  /* Centered brand hero (home page): the brand name is the large headline,
     then a small strap, then a graceful tagline, then the button, all centred.
     Scoped with :has so the centred heroes on the yoga and retreats pages are
     unaffected. The brand-name font-size needs this specificity to beat the
     generic `.hero p` rule. */
  .hero-content.centered:has(.brand-display) {
    padding-block: clamp(48px, 7vw, 96px);
  }

  .hero-content.centered .brand-display {
    font-size: clamp(42px, 6.6vw, 76px);
    line-height: 1.05;
    max-width: 13ch;
    margin: 0 auto 0.3em;
  }

  .hero-content.centered:has(.brand-display) h1.with-brand {
    font-size: clamp(13px, 1.55vw, 17px);
    letter-spacing: 2.5px;
    margin: 0 auto 1.3em;
  }

  .hero-content.centered:has(.brand-display) .hero-line {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(17px, 2vw, 23px);
    letter-spacing: 0.3px;
    line-height: 1.45;
    max-width: 34ch;
    margin: 0 auto 1.6em;
    color: #fff;
    text-shadow: 0 1px 12px rgba(17, 27, 39, 0.5);
  }

  /* Mobile, per Nadia's UAT walkthrough. A tall phone crop of a landscape
     hero keeps only the middle of the photo, losing the sea and the beach
     at the edges. Shorten the brand hero so more of the frame survives,
     and let pages steer the phone crop with focusMobile. */
  @media (max-width: 700px) {
    .hero-image {
      object-position: var(--focus-mobile, var(--focus, 50% 50%));
    }

    .hero:has(.brand-display) {
      min-height: min(58vh, 520px);
    }

    .hero-content.centered .brand-display {
      font-size: clamp(46px, 12vw, 76px);
    }
  }
</style>
