---
// The dark-sky section, the brand's signature move. Radial navy, cream
// headings, gold eyebrows. Every retreat page carries one.
interface Props {
  eyebrow: string;
  heading: string;
}

const { eyebrow, heading } = Astro.props;
---

<section class="dark-strip on-dark">
  <div class="narrow">
    <span class="eyebrow gold">{eyebrow}</span>
    <h2>{heading}</h2>
    <div class="dark-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .dark-strip {
    background: radial-gradient(ellipse at 50% 0%, #27384b 0%, #111b27 75%);
    padding-block: clamp(64px, 10vw, 120px);
    text-align: center;
  }

  .dark-strip h2 {
    color: var(--cream);
    margin-bottom: 0.8em;
  }

  .dark-body {
    color: var(--cream);
  }

  .dark-body :global(p) {
    color: var(--cream);
    margin-inline: auto;
    font-size: 17.5px;
    font-weight: 300;
  }

  .dark-body :global(a) {
    color: var(--gold);
  }
</style>
