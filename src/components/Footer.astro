---
// Footer: ink background, links row, NAP line, copyright, italic gold sign-off.
// Carries the sitewide MailerLite waitlist embed and the single universal
// loader script (async, non render-blocking, sanctioned by SPEC section 10).
import MailerLiteForm from './MailerLiteForm.astro';

const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Explore',
    links: [
      { label: 'Home', href: '/' },
      { label: 'Why Sark?', href: '/why-sark' },
      { label: 'The Practice', href: '/the-practice' },
      { label: 'Our Story', href: '/our-story' },
      { label: 'Meet the Team', href: '/meet-the-team' },
      { label: 'Journal', href: '/journal' },
    ],
  },
  {
    // One retreat, many doorways. These are facets of the September retreat,
    // not separate retreats, and the labels must read that way, per Nadia.
    heading: 'The Retreat Experience',
    links: [
      { label: 'Dates, Prices & Booking', href: '/retreats-on-sark' },
      { label: 'The Yoga', href: '/yoga-retreat-sark' },
      { label: 'A Digital Detox', href: '/digital-detox-retreat' },
      { label: 'Travelling Solo', href: '/solo-retreat-women' },
      { label: 'Rest & Recovery', href: '/burnout-retreat' },
      { label: 'The Dark Skies', href: '/dark-sky-retreat' },
    ],
  },
  {
    heading: 'Plan',
    links: [
      { label: 'Retreat FAQ', href: '/sark-island-yoga-retreat-faq' },
      // "Visiting Sark", not "guide": the only thing called a guide on this
      // site is the Getting to Sark free guide, per John, 14 July 2026.
      { label: 'Visiting Sark', href: '/visiting-sark-for-a-wellness-retreat' },
      { label: 'The Guide', href: '/free-guide' },
      { label: 'Booking Terms & Conditions', href: '/terms-conditions' },
      { label: 'Contact', href: '/contact' },
      { label: 'Reserve my place', href: '/retreats-on-sark' },
    ],
  },
];
---

{/* Clay planning band, per John, 14 July 2026: a quiet signpost above the
    footer to the Visiting Sark hub and the free guide. Clay as a wash with
    text links, not buttons, so the teal button rule holds. */}
<section class="plan-band">
  <div class="container">
    <p class="plan-q">Planning a visit?</p>
    <p class="plan-line">
      Read <a href="/visiting-sark-for-a-wellness-retreat">Visiting Sark</a>, everything about
      the island in one place, or have the
      <a href="/free-guide">Getting to Sark</a> guide sent to your inbox.
    </p>
  </div>
</section>

<section class="footer-cta">
  <div class="container">
    <span class="eyebrow">Sark in 2027</span>
    <h2>Our 2027 retreats, June and September</h2>
    <p>Our first 2027 dates are confirmed, 18 to 23 September, with June to follow soon. The waitlist hears everything first and chooses rooms at the best rate before booking opens to anyone else.</p>
    <div class="footer-actions">
      <MailerLiteForm slug="GIRqf4" cta="Join the 2027 waitlist" />
    </div>
  </div>
</section>

<footer class="site-footer on-dark">
  <div class="container">
    <div class="footer-links">
      {
        columns.map((col) => (
          <div>
            <h3>{col.heading}</h3>
            <ul>
              {col.links.map((l) => (
                <li>
                  <a href={l.href}>{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="footer-meta">
      <p class="nap">
        Sark Soul Island Retreats · Isle of Sark, Channel Islands · Founded &amp; hosted by Nadia
      </p>
      <p class="copyright">© {year} Sark Soul Island Retreats. All rights reserved.</p>
      <p class="signoff">Every season is a new adventure, Nadia 🌿 &amp; the team 🪷</p>
      <a
        class="instagram"
        href="https://www.instagram.com/sarksoulretreats"
        rel="noopener"
        aria-label="Sark Soul Island Retreats on Instagram"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2.5" y="2.5" width="19" height="19" rx="5.5"></rect>
          <circle cx="12" cy="12" r="4.5"></circle>
          <circle cx="17.3" cy="6.7" r="1.1" fill="currentColor" stroke="none"></circle>
        </svg>
      </a>
    </div>
  </div>
</footer>

<script is:inline>
  (function (w, d, e, u, f, l, n) {
    w[f] =
      w[f] ||
      function () {
        (w[f].q = w[f].q || []).push(arguments);
      };
    l = d.createElement(e);
    l.async = 1;
    l.src = u;
    n = d.getElementsByTagName(e)[0];
    n.parentNode.insertBefore(l, n);
  })(window, document, 'script', 'https://assets.mailerlite.com/js/universal.js', 'ml');
  ml('account', '2309024');
</script>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--cream);
    padding-block: clamp(56px, 8vw, 96px) 40px;
    margin-top: 0;
  }

  .plan-band {
    background: var(--clay);
    text-align: center;
    padding-block: clamp(14px, 2.2vw, 22px);
  }

  .plan-band p {
    max-width: 56ch;
    margin: 0 auto;
  }

  .plan-q {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(21px, 2.4vw, 25px);
    color: #fff;
    margin-bottom: 4px;
  }

  .plan-line {
    font-size: 16px;
    line-height: 1.65;
    color: rgba(255, 251, 245, 0.94);
  }

  .plan-band a {
    color: #fff;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .plan-band a:hover {
    color: var(--cream);
  }

  .footer-cta {
    background: var(--cream);
    border-top: 1px solid var(--cream-deep);
    text-align: center;
    padding-block: clamp(48px, 7vw, 80px);
  }

  .footer-cta .container {
    max-width: 640px;
  }

  .footer-cta h2 {
    color: var(--ink);
  }

  .footer-cta p {
    margin-inline: auto;
    color: var(--sage-dark);
  }

  .footer-actions {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 8px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 40px;
    padding-top: 8px;
  }

  .footer-links h3 {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 18px;
  }

  .footer-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .footer-links a {
    color: var(--cream);
    text-decoration: none;
    font-size: 15px;
    font-weight: 300;
  }

  .footer-links a:hover {
    color: var(--gold);
  }

  .footer-meta {
    border-top: 1px solid var(--ink-soft);
    margin-top: 48px;
    padding-top: 32px;
    text-align: center;
  }

  .footer-meta p {
    max-width: none;
    margin: 0 0 8px;
  }

  .nap {
    font-size: 14px;
    color: var(--cream);
  }

  .copyright {
    font-size: 13px;
    color: var(--cream-deep);
  }

  .signoff {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    color: var(--gold);
    margin-top: 16px;
  }

  .instagram {
    display: inline-flex;
    padding: 8px;
    margin-top: 12px;
    color: var(--cream);
  }

  .instagram:hover {
    color: var(--gold);
  }
</style>
