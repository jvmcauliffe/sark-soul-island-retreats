---
// Journal index: newest first, editorial card layout. Articles arrive from
// the Story Bank pipeline (windmill history, Dark Sky, coastal walks,
// occupation history are the planned first four).
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageSlot from '../../components/ImageSlot.astro';
import CTABand from '../../components/CTABand.astro';

const posts = (await getCollection('journal')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Journal · Sark Soul Island Retreats"
  description="Stories from the Isle of Sark: dark skies, coastal walks, island history and life at the retreat house, written by Nadia and the team."
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Journal', href: '/journal' },
  ]}
>
  <div class="container section">
    <span class="eyebrow">From the island</span>
    <h1>The Sark Journal</h1>
    <p>
      Stories from the island: its dark skies, its coastal paths, its history, and life at
      our historic farmhouse.
    </p>

    {
      posts.length === 0 ? (
        <div class="empty">
          <p>
            The first stories are on their way. In the meantime, start with
            <a href="/why-sark"> why we chose Sark</a> or see
            <a href="/retreats-on-sark"> this year's retreat dates</a>.
          </p>
        </div>
      ) : (
        <div class="cards">
          {posts.map((post) => (
            <article class="card">
              <a href={`/journal/${post.id}`} class="card-link">
                {post.data.heroImage ? (
                  <Image
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? `${post.data.title}, Sark`}
                    width={720}
                    height={480}
                    class="card-photo"
                  />
                ) : (
                  <ImageSlot
                    alt={post.data.heroImageAlt ?? `${post.data.title}, Sark`}
                    shot={post.data.heroShot ?? `Journal photo: ${post.data.title}`}
                    width={720}
                    height={480}
                  />
                )}
                <div class="card-body">
                  <span class="card-meta">
                    {formatDate(post.data.date)} · {post.data.author}
                  </span>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      )
    }
  </div>
  <CTABand />
</BaseLayout>

<style>
  .empty {
    background: var(--cream);
    border: 1px solid var(--cream-deep);
    padding: 40px;
    margin-top: 24px;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-top: 40px;
  }

  @media (min-width: 768px) {
    .cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .card-link :global(.card-photo) {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }

  .card-body {
    padding-top: 18px;
  }

  .card-meta {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--sage);
  }

  .card h2 {
    font-size: clamp(22px, 2.6vw, 28px);
    margin: 10px 0 8px;
  }

  .card-link:hover h2 {
    color: var(--teal-dark);
  }
</style>
