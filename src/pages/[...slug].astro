---
// Dynamic route for content-collection pages. Dropping one of John's copy
// files into src/content/pages/ makes it appear at its slug with the full
// retreat-page battery: attribution strip, DarkStrip, PriceCards, NadiaNote,
// FAQ and closing CTABand.
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AttributionStrip from '../components/AttributionStrip.astro';
import DarkStrip from '../components/DarkStrip.astro';
import PriceCards from '../components/PriceCards.astro';
import NadiaNote from '../components/NadiaNote.astro';
import FAQ from '../components/FAQ.astro';
import CTABand from '../components/CTABand.astro';
import MailerLiteForm from '../components/MailerLiteForm.astro';
import RoomCards from '../components/RoomCards.astro';
import FeatureRows from '../components/FeatureRows.astro';
import ImageSlot from '../components/ImageSlot.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => ({
    params: { slug: page.data.slug ?? page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);
const d = page.data;
const slug = d.slug ?? page.id;

const defaultNote =
  'Sark gives people something no timetable can, time that belongs to them again. That is the most transformative thing we offer.';

const breadcrumbs =
  d.retreatPage && slug !== 'retreats-on-sark'
    ? [
        { label: 'Home', href: '/' },
        { label: 'Retreats', href: '/retreats-on-sark' },
        { label: d.title, href: `/${slug}` },
      ]
    : [
        { label: 'Home', href: '/' },
        { label: d.title, href: `/${slug}` },
      ];
---

<BaseLayout
  title={d.metaTitle}
  description={d.metaDescription}
  ogImage={d.ogImage ?? d.heroImage?.src}
  event={d.retreatPage}
  breadcrumbs={breadcrumbs}
>
  <Hero
    eyebrow={d.heroEyebrow}
    title={d.heroTitle ?? d.title}
    line={d.heroLine}
    image={d.heroImage}
    imageAlt={d.heroImageAlt}
    shot={d.heroShot}
  />
  <AttributionStrip />

  <article class="prose section container">
    <Content />
  </article>

  {d.rooms.length > 0 && <RoomCards rooms={d.rooms} />}

  {
    d.includes && (
      <section class="section cream includes">
        <div class="container">
          <h2>{d.includes.heading}</h2>
          <ul>
            {d.includes.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  {
    d.addOns && (
      <section class="section addons">
        <div class="container">
          <h2>{d.addOns.heading}</h2>
          <p>{d.addOns.body}</p>
          <div class="addon-photos">
            {d.addOns.images.map((img) => (
              <ImageSlot src={img.src} alt={img.alt} shot={img.alt} width={800} height={600} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {d.features.length > 0 && <FeatureRows features={d.features} />}

  {
    d.travel.length > 0 && (
      <section class="section travel">
        <div class="narrow">
          {d.travel.map((t) => (
            <>
              <h2>{t.heading}</h2>
              <div class="prose" set:html={t.html} />
            </>
          ))}
        </div>
      </section>
    )
  }

  {!d.retreatPage && d.faqs.length > 0 && <FAQ items={d.faqs} />}

  {
    d.guideForm && (
      <section class="section cream" style="text-align: center;">
        <div class="narrow">
          <span class="eyebrow">Free travel guide</span>
          <h2>Get the Getting to Sark guide</h2>
          <p style="margin-inline: auto;">
            Ferry to farmhouse, everything you need for the journey over, straight to your inbox.
          </p>
          <MailerLiteForm slug="9SoA2F" cta="Send me the guide" />
        </div>
      </section>
    )
  }

  {
    d.retreatPage && (
      <>
        <DarkStrip
          eyebrow={d.darkStrip?.eyebrow ?? 'After dark'}
          heading={d.darkStrip?.heading ?? 'When the lights never come on, the sky does'}
        >
          <p>
            {d.darkStrip?.body ??
              'Sark has no street lighting, and in 2011 it became the world’s first Dark Sky Island. On clear September nights the Milky Way arrives without being asked.'}
          </p>
        </DarkStrip>
        <PriceCards />
        <NadiaNote quote={d.nadiaNote ?? defaultNote} />
        {d.faqs.length > 0 && <FAQ items={d.faqs} />}
        <CTABand />
      </>
    )
  }
</BaseLayout>

<style>
  .includes {
    text-align: center;
  }

  .includes ul {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 880px;
    display: grid;
    gap: 12px 40px;
    text-align: left;
  }

  @media (min-width: 640px) {
    .includes ul {
      grid-template-columns: 1fr 1fr;
    }
  }

  .includes li {
    padding-left: 26px;
    position: relative;
  }

  .includes li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 12px;
    height: 2px;
    background: var(--gold);
  }

  .addons {
    text-align: center;
    padding-top: 0;
  }

  .addons p {
    margin-inline: auto;
  }

  .addon-photos {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 28px;
  }

  .addon-photos :global(picture) {
    display: block;
  }

  .addon-photos :global(img),
  .addon-photos :global(.image-slot) {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .travel {
    padding-top: 0;
  }

  .travel h2 {
    margin-top: 1.4em;
  }

  .travel h2:first-child {
    margin-top: 0;
  }
</style>
