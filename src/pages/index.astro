---
// Home, migrated from the live Wix site with the known fixes applied.
// Copy is verbatim from the live homepage; the section order, the two
// retreat cards, the values strip, the starred testimonials, the dark
// guide panel and the Join Our Circle grid follow the live design,
// rebuilt with zero client side JavaScript.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AttributionStrip from '../components/AttributionStrip.astro';
import QRow from '../components/QRow.astro';
import DarkStrip from '../components/DarkStrip.astro';
import NadiaNote from '../components/NadiaNote.astro';
import CTABand from '../components/CTABand.astro';
import MailerLiteForm from '../components/MailerLiteForm.astro';
import GuidePanel from '../components/GuidePanel.astro';
import { Image } from 'astro:assets';
import laCoupee from '../assets/photos/sark-la-coupee-cliff-path.jpg';
import islandAerial from '../assets/photos/sark-island-aerial.jpg';
import monicaStudio from '../assets/photos/sark-monica-yogamorphic-studio.jpg';
import nadiaStudio from '../assets/photos/sark-nadia-founder-host-studio.jpg';
import retreatHouse from '../assets/photos/sark-retreat-house-aerial.jpg';
import circleArch from '../assets/photos/sark-wild-swim-rock-arch.jpg';
import circleGoat from '../assets/photos/sark-goat-carved-stone.jpg';
import circlePose from '../assets/photos/sark-yoga-childs-pose-class.jpg';
import circleSwim from '../assets/photos/sark-wild-swimming-cove.jpg';
import circleBuddha from '../assets/photos/sark-buddha-statue-garden.jpg';
import circleHenge from '../assets/photos/sark-henge-standing-stones-dusk.jpg';
import circleWarrior from '../assets/photos/sark-clifftop-yoga-warrior-pose.jpg';
import circleBay from '../assets/photos/sark-turquoise-bay-beach-path.jpg';
import circleCove from '../assets/photos/sark-rocky-cove-turquoise.jpg';
import circleMeadow from '../assets/photos/sark-meadow-yoga-pose.jpg';
import circleYachts from '../assets/photos/sark-harbour-bay-yachts.jpg';
import circleCurry from '../assets/photos/sark-vegetarian-curry-bowl.jpg';
import monicaCobra from '../assets/photos/sark-monica-cobra-pose-studio.jpg';
import laCoupeeSunny from '../assets/photos/sark-la-coupee-aerial-sunny.jpg';
import honeysuckleRoom from '../assets/photos/sark-honeysuckle-room.jpg';
import milkyWayHenge from '../assets/photos/sark-milky-way-dark-sky.jpg';
import venusPool from '../assets/photos/sark-venus-pool-wild-swimming.jpg';
import farmhousePoppies from '../assets/photos/sark-retreat-farmhouse-poppies.jpg';
import toastRack from '../assets/photos/sark-toast-rack-guests-arrival.jpg';

const testimonials = [
  {
    quote:
      'I just loved the whole experience. I was quite nervous about it all. Nadia met us as we got off the ferry. She could not have been more welcoming...',
    name: 'Yvonne · May 2026',
  },
  {
    quote:
      'The experience surpassed my expectations. Everyone really cared that we were getting the best out of our time on Sark. I came away feeling restored.',
    name: 'Anne · May 2026',
  },
  {
    quote:
      'From the first communication our host Nadia was kind, warm and welcoming. Monica is a wonderful yoga teacher. I would definitely recommend the retreat and look forward to returning.',
    name: 'Amanda · May 2026',
  },
  {
    quote:
      'I thoroughly enjoyed this retreat. Sark is a special island. I loved the camaraderie of our small group. The grounds are beautiful.. a warm and welcoming atmosphere',
    name: 'Maxine · May 2026',
  },
  {
    quote:
      'The food, and the chefs were fabulous. Everything was brilliantly organised. The location is stunning. Sark is such a beautiful place. I had the most wonderful time.',
    name: 'Andrea · May 2026',
  },
];

const circle = [
  { src: circleArch, alt: 'Wild swimming beneath a rock arch on the coast of Sark, Channel Islands' },
  { src: circleWarrior, alt: 'Warrior pose on the clifftop above the sea on Sark, Channel Islands' },
  { src: circleGoat, alt: 'A Sark goat standing on a carved stone on Sark' },
  { src: circleBay, alt: 'A grassy path down to a turquoise bay on Sark, Channel Islands' },
  { src: circlePose, alt: "Child's pose during a yoga class at the retreat on Sark" },
  { src: circleHenge, alt: 'Sark Henge standing stones at dusk on the Dark Sky Island of Sark' },
  { src: circleSwim, alt: 'Guests swimming in a sheltered turquoise cove on Sark, Channel Islands' },
  { src: circleMeadow, alt: 'A yoga pose in a wildflower meadow on Sark' },
  { src: circleBuddha, alt: 'Buddha statue in the garden of the retreat house on Sark' },
  { src: circleYachts, alt: 'Yachts at anchor in a turquoise bay on Sark, Channel Islands' },
  { src: circleCurry, alt: 'A vegetarian curry bowl at the retreat on Sark' },
  { src: circleCove, alt: 'A rocky turquoise cove on the coast of Sark, Channel Islands' },
  { src: monicaCobra, alt: 'Monica in cobra pose in the yoga studio at the retreat on Sark' },
  { src: laCoupeeSunny, alt: 'La Coupée and its turquoise bays from the air on Sark, Channel Islands' },
  { src: honeysuckleRoom, alt: 'The Honeysuckle room at the retreat house on Sark' },
  { src: milkyWayHenge, alt: 'The Milky Way over Sark Henge on the Dark Sky Island of Sark' },
  { src: venusPool, alt: 'Wild swimming at the Venus Pool on Sark, Channel Islands' },
  { src: farmhousePoppies, alt: 'The historic farmhouse behind summer poppies on Sark' },
  { src: toastRack, alt: 'Guests riding the tractor-drawn toast rack on Sark' },
  { src: retreatHouse, alt: 'The retreat house and gardens from the air on Sark, Channel Islands' },
];
---

<BaseLayout
  title="Sark Soul Island Retreats | Yoga Retreats, Isle of Sark"
  description="Intimate five-night yoga retreats on Sark, the world's first Dark Sky Island. Next retreat 12 to 17 September 2026, an hour from the UK and Europe."
>
  <Hero
    eyebrow="Isle of Sark · Channel Islands"
    brand={true}
    centered={true}
    title="Yoga & Nature Retreats on Sark Island"
    line="Intimate five-night retreats on the world's first Dark Sky Island, an hour from the UK and Europe, a world away from everything else."
    image={laCoupee}
    imageAlt="The cliff path across La Coupée between Sark and Little Sark, Channel Islands"
    shot="Hero, clifftop or coastal golden hour, landscape"
    focusMobile="62% 45%"
  />
  <AttributionStrip />

  <section class="retreat-cards container">
    <a class="retreat-card" href="/retreats-on-sark">
      <Image src={circleBay} alt="A grassy path down to a turquoise bay on Sark, Channel Islands" width={880} height={620} class="retreat-card-img" />
      <div class="retreat-card-scrim" aria-hidden="true"></div>
      <div class="retreat-card-body">
        <h2>Late Summer Retreat</h2>
        <p>12 to 17 September 2026</p>
        <span class="btn">Reserve my place</span>
      </div>
    </a>
    <a class="retreat-card" href="/contact">
      <Image src={circleYachts} alt="Yachts at anchor in a turquoise bay on Sark, Channel Islands" width={880} height={620} class="retreat-card-img" />
      <div class="retreat-card-scrim" aria-hidden="true"></div>
      <div class="retreat-card-body">
        <h2>Early Summer Retreat</h2>
        <p>2027 dates coming soon</p>
        <span class="btn">Join the waitlist</span>
      </div>
    </a>
  </section>

  <section class="section" style="text-align: center; padding-top: 0;">
    <div class="narrow">
      <p style="margin-inline: auto;">
        A small group, twice a year, in a historic farmhouse by the sea. Twice daily yoga,
        coastal walks, nourishing food, and the kind of quiet most people haven't experienced
        in years.
      </p>
    </div>
  </section>

  <section class="section cream">
    <div class="container" style="text-align: center;">
      <h2>What guests say</h2>
      <p class="testimonials-sub">In their own words</p>
      <div class="testimonials">
        {
          testimonials.map((t) => (
            <blockquote>
              <span class="stars" aria-label="Five stars">★★★★★</span>
              <p>"{t.quote}"</p>
              <cite>{t.name}</cite>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <section class="henge-band">
    <Image
      src={circleHenge}
      alt="Sark Henge standing stones at golden hour above the sea on Sark, Channel Islands"
      width={1510}
      height={832}
      class="henge-band-img"
      loading="lazy"
    />
  </section>

  <QRow
    question="The world's first Dark Sky Island"
    eyebrow="The setting"
    image={islandAerial}
    imageAlt="Aerial view of car-free Sark surrounded by open sea, Channel Islands"
    shot="Island aerial"
    caption="Sark, Channel Islands. Car-free, no streetlights, no rush."
  >
    <p>
      Sark Soul Island Retreats hosts intimate yoga retreats on Sark Island in the Channel
      Islands. Our small group immersions are designed for those seeking deep rest, reconnection
      and space away from mainland pace. This yoga retreat welcomes both experienced
      practitioners and curious newcomers.
    </p>
    <p>
      From the moment you step off the boat, distraction falls away. Crystal clear seas where
      dolphins pass most days, quiet lanes travelled on foot, by bicycle or by horse and
      carriage, and a pace of life that feels like going back in time. Twice daily yoga,
      coastal walks, wild swimming and nourishing seasonal food support genuine restoration,
      and when night falls,
      the world's first Dark Sky Island reveals more stars than you have ever seen.
      <a href="/why-sark">Why Sark?</a>
    </p>
  </QRow>

  <GuidePanel />

  <QRow
    question="Led by Monica, our teacher"
    eyebrow="The practice"
    image={monicaStudio}
    imageAlt="Senior yoga teacher Monica of YogaMorphic in the studio on Sark"
    shot="Monica in the studio"
    caption="Monica of YogaMorphic, senior yoga teacher."
    reverse
  >
    <p>
      Every retreat is led by Monica, who has taught yoga for over twenty years. Accredited by
      the British Wheel of Yoga and Yoga Alliance, her teaching is intuitive and grounded:
      depth without performance, challenge without pressure. She meets you where you are.
    </p>
    <p>
      Whether it's your first week on a mat or your fifteenth year, you'll be looked after.
      Morning and evening sessions frame each day, drawing on asana, pranayama and meditation.
      The practice is the thread that holds the week together.
      <a href="/the-practice">The practice</a>
    </p>
  </QRow>

  <QRow
    question="Created and Hosted by Nadia"
    eyebrow="The founder"
    image={nadiaStudio}
    imageAlt="Nadia, founder and host, in the yoga studio at the retreat house on Sark"
    shot="Nadia at the retreat house"
    caption="Nadia, founder and host."
  >
    <p>
      Sark Soul Island Retreats was founded by Nadia, who fell for the island's stillness and
      built a retreat around it. She hosts every gathering personally, and she's who you'll be
      speaking to from your first enquiry to your last morning.
    </p>
    <p>
      <a href="/our-story">Our story</a> · <a href="/meet-the-team">Meet the team</a>
    </p>
  </QRow>

  <section class="values-photos">
    <Image src={circleCove} alt="A rocky turquoise cove on the coast of Sark, Channel Islands" width={700} height={620} class="vp-img" loading="lazy" />
    <Image src={circleMeadow} alt="A yoga pose in a wildflower meadow on Sark" width={700} height={620} class="vp-img" loading="lazy" />
    <Image src={circleCurry} alt="A vegetarian curry bowl at the retreat on Sark" width={700} height={620} class="vp-img" loading="lazy" />
    <Image src={monicaCobra} alt="Monica in cobra pose in the yoga studio at the retreat on Sark" width={700} height={620} class="vp-img" loading="lazy" />
  </section>

  <section class="values section on-dark">
    <h2 class="values-title">Come join us</h2>
    <div class="container values-grid">
      <div>
        <h3>- A place to arrive -</h3>
        <p>
          Held within a historic farmhouse surrounded by stunning gardens, this is more than a
          beautiful setting, it is a place that naturally slows the body and quiets the mind.
          The setting supports rest, reflection, and a gentle return to yourself.
        </p>
      </div>
      <div>
        <h3>- A yoga retreat in the Channel Islands -</h3>
        <p>
          Sark sits a short ferry from Guernsey, an hour from the UK and Europe, a world away from
          everything else. Plenty of guests first meet the island on a day trip, then find
          themselves wanting more than a few hours. A week is how you really feel the place
          settle into you, and the retreat is what makes that week count: twice daily yoga,
          meditation, nourishing food and days shaped around genuine rest.
        </p>
      </div>
      <div>
        <h3>- Balancing practice &amp; ease -</h3>
        <p>
          Spacious days, time to rest, sea air, coastal walks, turquoise coves, daily swims,
          shared meals, with morning and evening Yoga framing the day. Life on Sark is simple
          and unhurried, offering space to breathe, move, and settle.
        </p>
      </div>
    </div>
  </section>


  <DarkStrip eyebrow="After dark" heading="More stars than you have ever seen. The first Dark Sky Island on Earth.">
    <p>
      When night falls, the world's first Dark Sky Island reveals its greatest gift. A guided
      night-sky session at the Sark Observatory is part of every retreat.
      <a href="/dark-sky-retreat">Sark after dark</a>.
    </p>
    <p style="font-family: var(--font-display); font-style: italic; font-size: 1.3em;">
      "There is no island in the world that I love more"
    </p>
    <p style="font-size: 12px; letter-spacing: 2.5px; text-transform: uppercase;">Victor Hugo</p>
  </DarkStrip>

  <section class="house-band">
    <Image
      src={retreatHouse}
      alt="The historic farmhouse and its gardens from the air on Sark, Channel Islands"
      width={1800}
      height={700}
      class="house-band-img"
      loading="lazy"
    />
    <div class="container house-band-body">
      <h2>Your home for the week</h2>
      <p>Find out more about our retreats</p>
      <a class="btn" href="/retreats-on-sark">See the retreat</a>
    </div>
  </section>

  <section class="section" style="text-align: center; padding-top: clamp(28px, 4vw, 48px);">
    <div class="container">
      <div class="circle-grid">
        {
          circle.map((c) => (
            <div class="circle-tile">
              <Image src={c.src} alt={c.alt} width={520} height={520} class="circle-img" loading="lazy" />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <NadiaNote
    quote="People arrive carrying more than their luggage. Somewhere between the morning practice, the sea air and the quiet, the weight begins to lift. That is the transformative part, and we shape every day of the retreat around it."
  />

  <CTABand />

  <section class="wa-channel">
    <p>Prefer to talk to a person? Nadia reads and replies to every email herself.</p>
    <a class="btn" href="mailto:info@sarksoulretreats.com?subject=September%20retreat">Email Nadia</a>
  </section>
</BaseLayout>

<style>
  .retreat-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    padding-block: clamp(28px, 4vw, 48px);
  }

  @media (min-width: 700px) {
    .retreat-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .retreat-card {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 16 / 9;
  }

  /* A little more photo on phones, where the card is the full viewport
     width and 16/9 leaves it shallow. */
  @media (max-width: 699px) {
    .retreat-card {
      aspect-ratio: 4 / 3;
    }
  }

  .retreat-card :global(.retreat-card-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .retreat-card:hover :global(.retreat-card-img) {
    transform: scale(1.03);
  }

  .retreat-card-scrim {
    /* Deep enough in the middle that "Late Summer Retreat" reads over a
       bright sky and sea, per Nadia's UAT. */
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(17, 27, 39, 0.72),
      rgba(17, 27, 39, 0.34) 55%,
      rgba(17, 27, 39, 0.14)
    );
  }

  .retreat-card-body {
    /* Bottom weighted, per Nadia: the title and button sit low over the
       darkest part of the scrim, so the middle of the photo, the bay and
       the beach, stays in view. */
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    gap: 4px;
    padding: 20px 20px 22px;
  }

  .retreat-card-body h2 {
    color: #fff;
    margin: 0;
    text-shadow: 0 2px 18px rgba(17, 27, 39, 0.6), 0 1px 3px rgba(17, 27, 39, 0.45);
  }

  .retreat-card-body p {
    color: var(--cream);
    margin: 0 0 14px;
    text-shadow: 0 1px 12px rgba(17, 27, 39, 0.55);
  }

  /* A quieter button on the cards so the photo stays the hero. Still teal
     per the guardrail; the soft shadow lifts it off the sea behind it. */
  .retreat-card-body .btn {
    padding: 10px 22px;
    font-size: 12px;
    letter-spacing: 1.3px;
    box-shadow: 0 3px 14px rgba(17, 27, 39, 0.3);
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
  }

  @media (min-width: 820px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .values-grid h3 {
    margin-bottom: 0.5em;
  }

  .values-grid p {
    max-width: none;
  }

  .testimonials {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 86%;
    gap: 20px;
    margin-top: 40px;
    text-align: left;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 14px;
    scrollbar-width: thin;
    scrollbar-color: var(--cream-deep) transparent;
  }

  .testimonials-sub {
    margin: -6px auto 0;
    color: var(--sage-dark);
    font-size: 15px;
  }

  @media (min-width: 1040px) {
    .testimonials {
      grid-auto-flow: row;
      grid-template-columns: repeat(5, 1fr);
      grid-auto-columns: auto;
      overflow-x: visible;
      gap: 16px;
    }
  }

  
  .testimonials blockquote {
    margin: 0;
    background: var(--paper);
    border: 1px solid var(--cream-deep);
    padding: 28px;
    scroll-snap-align: start;
  }

  .stars {
    display: block;
    color: var(--gold);
    font-size: 15px;
    letter-spacing: 4px;
    margin-bottom: 12px;
  }

  .testimonials p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .testimonials cite {
    font-style: normal;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--sage);
  }

  .circle-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  @media (min-width: 700px) {
    .circle-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  /* Each tile clips its photo so the hover zoom stays inside the square. */
  .circle-tile {
    overflow: hidden;
    aspect-ratio: 1;
  }

  .circle-grid :global(.circle-img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
  }

  .circle-tile:hover :global(.circle-img) {
    transform: scale(1.06);
  }

  @media (prefers-reduced-motion: reduce) {
    .circle-grid :global(.circle-img) {
      transition: none;
    }

    .circle-tile:hover :global(.circle-img) {
      transform: none;
    }
  }

  .henge-band :global(.henge-band-img) {
    width: 100%;
    height: clamp(300px, 52vw, 620px);
    object-fit: cover;
    display: block;
  }

  .values-photos {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 760px) {
    .values-photos {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .values-photos :global(.vp-img) {
    width: 100%;
    height: clamp(200px, 24vw, 320px);
    object-fit: cover;
    display: block;
  }

  .values.on-dark {
    background: var(--teal);
  }

  .values-title {
    text-align: center;
    color: #fff;
    margin-bottom: 1.2em;
  }

  .values.on-dark h3 {
    color: #fff;
    text-align: center;
    font-size: 20px;
  }

  .values.on-dark p {
    color: rgba(255, 255, 255, 0.92);
    text-align: center;
    font-size: 15px;
  }

  .house-band :global(.house-band-img) {
    width: 100%;
    height: clamp(280px, 42vw, 560px);
    object-fit: cover;
    display: block;
  }

  .house-band-body {
    padding-block: clamp(28px, 4vw, 48px);
  }

  .house-band-body h2 {
    margin-bottom: 0.2em;
  }

  .house-band-body p {
    color: var(--sage-dark);
    margin-bottom: 1.4em;
  }
</style>