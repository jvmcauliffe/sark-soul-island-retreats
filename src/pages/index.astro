---
// Home, migrated from the live Wix site with the known fixes applied.
// Copy is verbatim from the live homepage; the section order, the two
// retreat cards, the values strip, the starred testimonials, the dark
// guide panel and the Join Our Circle grid follow the live design,
// rebuilt with zero client side JavaScript.
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AttributionStrip from '../components/AttributionStrip.astro';
import QRow from '../components/QRow.astro';
import DarkStrip from '../components/DarkStrip.astro';
import NadiaNote from '../components/NadiaNote.astro';
import CTABand from '../components/CTABand.astro';
import MailerLiteForm from '../components/MailerLiteForm.astro';
import { Image } from 'astro:assets';
import laCoupee from '../assets/photos/sark-la-coupee-cliff-path.jpg';
import islandAerial from '../assets/photos/sark-island-aerial.jpg';
import monicaStudio from '../assets/photos/sark-monica-yogamorphic-studio.jpg';
import nadiaStudio from '../assets/photos/sark-nadia-founder-host-studio.jpg';
import retreatHouse from '../assets/photos/sark-retreat-house-aerial.jpg';
import coastalWalk from '../assets/photos/sark-coastal-path-walk.jpg';
import headlandView from '../assets/photos/sark-la-coupee-headland-view.jpg';
import milkyWay from '../assets/photos/sark-milky-way-dark-sky.jpg';
import circleArch from '../assets/photos/sark-wild-swim-rock-arch.jpg';
import circleGoat from '../assets/photos/sark-goat-carved-stone.jpg';
import circlePose from '../assets/photos/sark-yoga-childs-pose-class.jpg';
import circleSwim from '../assets/photos/sark-wild-swimming-cove.jpg';
import circleBuddha from '../assets/photos/sark-buddha-statue-garden.jpg';
import circleHenge from '../assets/photos/sark-henge-standing-stones-dusk.jpg';
import circleWarrior from '../assets/photos/sark-clifftop-yoga-warrior-pose.jpg';
import circleBay from '../assets/photos/sark-turquoise-bay-beach-path.jpg';
import circleCove from '../assets/photos/sark-rocky-cove-turquoise.jpg';
import circleMeadow from '../assets/photos/sark-meadow-yoga-pose.jpg';
import circleYachts from '../assets/photos/sark-harbour-bay-yachts.jpg';
import circleCurry from '../assets/photos/sark-vegetarian-curry-bowl.jpg';

const testimonials = [
  {
    quote:
      'I just loved the whole experience. I was quite nervous about it all. Nadia met us as we got off the ferry. She could not have been more welcoming...',
    name: 'Yvonne · May 2026',
  },
  {
    quote:
      'The experience surpassed my expectations. Everyone really cared that we were getting the best out of our time on Sark. I came away feeling restored.',
    name: 'Anne · May 2026',
  },
  {
    quote:
      'From the first communication our host Nadia was kind, warm and welcoming. Monica is a wonderful yoga teacher. I would definitely recommend the retreat and look forward to returning.',
    name: 'Amanda · May 2026',
  },
  {
    quote:
      'I thoroughly enjoyed this retreat. Sark is a special island. I loved the camaraderie of our small group. The grounds are beautiful.. a warm and welcoming atmosphere',
    name: 'Maxine · May 2026',
  },
  {
    quote:
      'The food, and the chefs were fabulous. Everything was brilliantly organised. The location is stunning. Sark is such a beautiful place. I had the most wonderful time.',
    name: 'Andrea · May 2026',
  },
];

const circle = [
  { src: circleArch, alt: 'Wild swimming beneath a rock arch on the coast of Sark, Channel Islands' },
  { src: circleWarrior, alt: 'Warrior pose on the clifftop above the sea on Sark, Channel Islands' },
  { src: circleGoat, alt: 'A Sark goat standing on a carved stone on Sark' },
  { src: circleBay, alt: 'A grassy path down to a turquoise bay on Sark, Channel Islands' },
  { src: circlePose, alt: "Child's pose during a yoga class at the retreat on Sark" },
  { src: circleHenge, alt: 'Sark Henge standing stones at dusk on the Dark Sky Island of Sark' },
  { src: circleSwim, alt: 'Guests swimming in a sheltered turquoise cove on Sark, Channel Islands' },
  { src: circleMeadow, alt: 'A yoga pose in a wildflower meadow on Sark' },
  { src: circleBuddha, alt: 'Buddha statue in the garden of the retreat house on Sark' },
  { src: circleYachts, alt: 'Yachts at anchor in a turquoise bay on Sark, Channel Islands' },
  { src: circleCurry, alt: 'A vegetarian curry bowl at the retreat on Sark' },
  { src: circleCove, alt: 'A rocky turquoise cove on the coast of Sark, Channel Islands' },
];
---

<BaseLayout
  title="Sark Soul Island Retreats | Yoga Retreats, Isle of Sark"
  description="Yoga and nature retreats on Sark Island. Intimate five-night retreats on the world's first Dark Sky Island, half a day from London, a world away."
>
  <Hero
    eyebrow="Isle of Sark · Channel Islands"
    brand={true}
    title="Yoga & Nature Retreats on Sark Island"
    line="Intimate five-night retreats on the world's first Dark Sky Island, half a day from London, a world away from everything else."
    image={laCoupee}
    imageAlt="The cliff path across La Coupée between Sark and Little Sark, Channel Islands"
    shot="Hero, clifftop or coastal golden hour, landscape"
  />
  <AttributionStrip />

  <section class="retreat-cards container">
    <a class="retreat-card" href="/retreats-on-sark">
      <Image src={coastalWalk} alt="" width={880} height={620} class="retreat-card-img" />
      <div class="retreat-card-scrim" aria-hidden="true"></div>
      <div class="retreat-card-body">
        <h2>Late Summer Retreat</h2>
        <p>12 to 17 September 2026</p>
        <span class="btn">Reserve my place</span>
      </div>
    </a>
    <a class="retreat-card" href="/contact">
      <Image src={headlandView} alt="" width={880} height={620} class="retreat-card-img" />
      <div class="retreat-card-scrim" aria-hidden="true"></div>
      <div class="retreat-card-body">
        <h2>Early Summer Retreat</h2>
        <p>2027 dates coming soon</p>
        <span class="btn">Join the waitlist</span>
      </div>
    </a>
  </section>

  <section class="section" style="text-align: center; padding-top: 0;">
    <div class="narrow">
      <p style="margin-inline: auto;">
        A small group, twice a year, in a historic farmhouse by the sea. Daily yoga, coastal
        walks, nourishing food, and the kind of quiet most people haven't experienced in years.
      </p>
    </div>
  </section>

  <QRow
    question="The world's first Dark Sky Island"
    eyebrow="The setting"
    image={islandAerial}
    imageAlt="Aerial view of car-free Sark surrounded by open sea, Channel Islands"
    shot="Island aerial"
    caption="Sark, Channel Islands. Car-free, no streetlights, no rush."
  >
    <p>
      Sark Soul Island Retreats hosts intimate yoga retreats on Sark Island in the Channel
      Islands. Our small group immersions are designed for those seeking deep rest, reconnection
      and space away from mainland pace. This yoga retreat welcomes both experienced
      practitioners and curious newcomers.
    </p>
    <p>
      From the moment you step off the boat, distraction falls away. There are no cars, no
      streetlights, no rush. Daily yoga, coastal walks and nourishing seasonal food support
      genuine restoration, and when night falls, the world's first Dark Sky Island reveals its
      greatest gift. <a href="/why-sark">Why Sark?</a>
    </p>
  </QRow>

  <QRow
    question="Led by Monica, our teacher"
    eyebrow="The practice"
    image={monicaStudio}
    imageAlt="Senior yoga teacher Monica of YogaMorphic in the studio on Sark"
    shot="Monica in the studio"
    caption="Monica of YogaMorphic, senior yoga teacher."
    reverse
  >
    <p>
      Each day opens and closes with yoga. Morning practice to wake the body gently, evening
      practice to let the day settle. Monica Marini leads every session, drawing on around
      thirty years of teaching. Her style is warm and unhurried, with room for both seasoned
      practitioners and those returning to the mat after time away.
    </p>
    <p>
      You will never be pushed to perform. Sessions are small by design, so the teaching meets
      you where you are. Between practices, the days are yours: coastal walks, sea swims, quiet
      corners for rest. <a href="/the-practice">The practice</a>
    </p>
  </QRow>

  <QRow
    question="Created and Hosted by Nadia"
    eyebrow="The founder"
    image={nadiaStudio}
    imageAlt="Nadia, founder and host, in the yoga studio at the retreat house on Sark"
    shot="Nadia at the retreat house"
    caption="Nadia, founder and host."
  >
    <p>
      Sark Soul Island Retreats was founded by Nadia, who fell for the island's stillness and
      built a retreat around it. She hosts every gathering personally, and she's who you'll be
      speaking to from your first enquiry to your last morning.
    </p>
    <p>
      <a href="/our-story">Our story</a> · <a href="/meet-the-team">Meet the team</a>
    </p>
  </QRow>

  <section class="values section cream">
    <div class="container values-grid">
      <div>
        <h3>A place to arrive</h3>
        <p>
          Held within a historic farmhouse surrounded by stunning gardens, this is more than a
          beautiful setting, it is a place that naturally slows the body and quiets the mind.
          The setting supports rest, reflection, and a gentle return to yourself.
        </p>
      </div>
      <div>
        <h3>A yoga retreat in the Channel Islands</h3>
        <p>
          Sark sits a short ferry from Guernsey, half a day from London and a world away from
          everything else. Plenty of guests first meet the island on a day trip, then find
          themselves wanting more than a few hours. A week is how you really feel the place
          settle into you.
        </p>
      </div>
      <div>
        <h3>Balancing practice &amp; ease</h3>
        <p>
          Spacious days, time to rest, sea air, coastal walks, turquoise coves, daily swims,
          shared meals, with morning and evening Yoga framing the day. Life on Sark is simple
          and unhurried, offering space to breathe, move, and settle.
        </p>
      </div>
    </div>
  </section>

  <DarkStrip eyebrow="After dark" heading="No street lighting. The first Dark Sky Island on Earth.">
    <p>
      When night falls, the world's first Dark Sky Island reveals its greatest gift. A guided
      night-sky session at the Sark Observatory is part of every retreat.
      <a href="/dark-sky-retreat">Our Dark Sky retreat</a> is built around it.
    </p>
    <p style="font-family: var(--font-display); font-style: italic; font-size: 1.3em;">
      "There is no island in the world that I love more"
    </p>
    <p style="font-size: 12px; letter-spacing: 2.5px; text-transform: uppercase;">Victor Hugo</p>
  </DarkStrip>

  <QRow
    question="Your home for the week"
    eyebrow="A place to arrive"
    image={retreatHouse}
    imageAlt="Our historic farmhouse and its gardens from the air on Sark, Channel Islands"
    shot="The retreat house"
    caption="Our historic farmhouse and its gardens."
    reverse
  >
    <p>
      Your retreat house is one of Sark's most beautiful historic farmhouses. A small private
      estate surrounded by gardens, woodland, and birdsong. It's intimate, warm, and deeply
      peaceful, the perfect setting for a soulful retreat.
    </p>
    <p>
      <a href="/retreats-on-sark">Find out more about our retreats</a>
    </p>
  </QRow>

  <section class="section cream">
    <div class="container" style="text-align: center;">
      <span class="eyebrow">What guests say</span>
      <h2>In their own words</h2>
      <div class="testimonials">
        {
          testimonials.map((t) => (
            <blockquote>
              <span class="stars" aria-label="Five stars">★★★★★</span>
              <p>"{t.quote}"</p>
              <cite>{t.name}</cite>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>


  <NadiaNote
    quote="People arrive with their shoulders somewhere near their ears. By the second morning on Sark, they have let them down. That is the transformative part, and the island does most of it."
  />

  <section class="guide-panel on-dark">
    <div class="guide-media">
      <Image
        src={milkyWay}
        alt="The Milky Way over Sark Henge on Sark, the world's first Dark Sky Island"
        width={980}
        height={1354}
        class="guide-img"
        loading="lazy"
      />
    </div>
    <div class="guide-content">
      <span class="eyebrow gold">Free Guide</span>
      <h2>Getting to Sark</h2>
      <p>
        Guests used to ask me the same things before they came, and I loved answering. So I
        gathered it all into this little guide: the ferry, the famous luggage system, what the
        first evening feels like.
      </p>
      <p class="guide-sig">Nadia, founder and host</p>
      <MailerLiteForm slug="9SoA2F" cta="Send me the guide" />
      <p class="guide-fine">No spam, just island news now and then. Unsubscribe anytime.</p>
    </div>
  </section>

  <section class="section" style="text-align: center;">
    <div class="container">
      <span class="eyebrow">Join our circle</span>
      <h2>Follow us @sarksoulretreats</h2>
      <div class="circle-grid">
        {
          circle.map((c) => (
            <a href="https://www.instagram.com/sarksoulretreats" rel="noopener">
              <Image src={c.src} alt={c.alt} width={520} height={520} class="circle-img" loading="lazy" />
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>

<style>
  .retreat-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    padding-block: clamp(28px, 4vw, 48px);
  }

  @media (min-width: 700px) {
    .retreat-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  .retreat-card {
    position: relative;
    display: block;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 16 / 9;
  }

  .retreat-card :global(.retreat-card-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .retreat-card:hover :global(.retreat-card-img) {
    transform: scale(1.03);
  }

  .retreat-card-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17, 27, 39, 0.72), rgba(17, 27, 39, 0.15) 60%);
  }

  .retreat-card-body {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 4px;
    padding: 20px;
  }

  .retreat-card-body h2 {
    color: #fff;
    margin: 0;
  }

  .retreat-card-body p {
    color: var(--cream);
    margin: 0 0 14px;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
  }

  @media (min-width: 820px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .values-grid h3 {
    margin-bottom: 0.5em;
  }

  .values-grid p {
    max-width: none;
  }

  .testimonials {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 86%;
    gap: 20px;
    margin-top: 40px;
    text-align: left;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 14px;
    scrollbar-width: thin;
    scrollbar-color: var(--cream-deep) transparent;
  }

  @media (min-width: 768px) {
    .testimonials {
      grid-auto-columns: calc((100% - 40px) / 3);
    }
  }

  .testimonials blockquote {
    margin: 0;
    background: var(--paper);
    border: 1px solid var(--cream-deep);
    padding: 28px;
    scroll-snap-align: start;
  }

  .stars {
    display: block;
    color: var(--gold);
    font-size: 15px;
    letter-spacing: 4px;
    margin-bottom: 12px;
  }

  .testimonials p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  .testimonials cite {
    font-style: normal;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--sage);
  }

  .guide-panel {
    display: grid;
    grid-template-columns: 1fr;
    background: var(--ink-soft);
  }

  @media (min-width: 800px) {
    .guide-panel {
      grid-template-columns: 1fr 1fr;
    }
  }

  .guide-media {
    min-height: 320px;
  }

  .guide-panel :global(.guide-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    display: block;
  }

  .guide-content {
    padding: clamp(48px, 6vw, 96px) clamp(24px, 5vw, 80px);
    text-align: left;
    align-self: center;
    max-width: 620px;
  }

  .guide-content .eyebrow {
    font-size: 15px;
    letter-spacing: 6px;
  }

  .guide-content h2 {
    color: #fff;
    letter-spacing: 2px;
    margin-bottom: 0.4em;
  }

  .guide-content p {
    color: var(--cream);
    margin-inline: 0;
  }

  .guide-sig {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    color: var(--cream);
    text-align: center;
    max-width: none;
    margin: 1.6em 0;
  }

  .guide-content :global(.ml-embedded) {
    margin-inline: 0;
  }

  .guide-fine {
    font-size: 13px;
    color: var(--cream-deep);
    margin-top: 14px;
    text-align: center;
    max-width: none;
  }

  .circle-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-top: 36px;
  }

  @media (min-width: 700px) {
    .circle-grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .circle-grid a {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .circle-grid :global(.circle-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .circle-grid a:hover :global(.circle-img) {
    transform: scale(1.05);
  }
</style>
