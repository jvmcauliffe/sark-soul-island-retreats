---
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/jost/300.css';
import '@fontsource/jost/400.css';
import '@fontsource/jost/500.css';
import '../styles/global.css';

import jostBody from '@fontsource/jost/files/jost-latin-300-normal.woff2?url';
import cormorantDisplay from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-normal.woff2?url';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  breadcrumbs?: Crumb[];
  event?: boolean;
  article?: {
    headline: string;
    description: string;
    datePublished: string;
    author: string;
  };
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogImage = '/og-default.jpg',
  breadcrumbs = [],
  event = false,
  article,
} = Astro.props;

const site = 'https://www.sarksoulretreats.com';
const canonical = new URL(Astro.url.pathname.replace(/\/$/, '') || '/', site).href;
const ogImageUrl = new URL(ogImage, site).href;

const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: new URL(c.href, site).href,
        })),
      }
    : null;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preload" as="font" type="font/woff2" href={jostBody} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={cormorantDisplay} crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sark Soul Island Retreats" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <Schema canonical={canonical} event={event} article={article} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    {
      /* GA4 ships only when PUBLIC_GA4_ID is set in the build environment.
         Lightweight direct gtag include per SPEC section 10, loaded async. */
      import.meta.env.PUBLIC_GA4_ID && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}
          />
          <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA4_ID }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
    <slot name="head" />
  </head>
  <body>
    <a class="visually-hidden" href="#main">Skip to content</a>
    <Header />
    <p class="promo-banner">Early booking rate ends 19 July - <a class="promo-gold" href="/retreats-on-sark">limited places available</a></p>
    <main id="main">
      <slot />
    </main>
    <Footer />
    {/* Same-tab navigation and the api.whatsapp.com host are deliberate: the
        wa.me redirect hop plus target=_blank breaks the app handoff on iOS
        Safari and in-app browsers, bouncing between tab and app. */}
    <a
      class="chat-btn"
      href="https://api.whatsapp.com/send?phone=447444133015&text=Hello%20Nadia%2C%20I%27m%20interested%20in%20the%20September%20retreat"
      aria-label="Chat with us on WhatsApp"
    >
      <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
        <path d="M12 2a9.94 9.94 0 0 0-8.59 15L2 22l5.15-1.35A10 10 0 1 0 12 2Zm0 18.13a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.06.8.82-2.98-.2-.3A8.13 8.13 0 1 1 12 20.13Zm4.46-6.08c-.24-.12-1.44-.71-1.66-.79s-.39-.12-.55.12-.63.79-.77.95-.28.18-.53.06a6.65 6.65 0 0 1-1.95-1.2 7.3 7.3 0 0 1-1.35-1.68c-.14-.24 0-.37.11-.5s.24-.28.37-.42a1.68 1.68 0 0 0 .24-.41.45.45 0 0 0 0-.43c-.06-.12-.55-1.32-.75-1.81s-.4-.41-.55-.42h-.47a.9.9 0 0 0-.65.3 2.73 2.73 0 0 0-.85 2 4.74 4.74 0 0 0 1 2.52 10.88 10.88 0 0 0 4.16 3.68 14 14 0 0 0 1.39.51 3.35 3.35 0 0 0 1.53.1 2.5 2.5 0 0 0 1.64-1.16 2 2 0 0 0 .14-1.16c-.06-.1-.22-.16-.46-.28Z" />
      </svg>
    </a>
  </body>
</html>
