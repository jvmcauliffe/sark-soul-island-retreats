---
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/jost/300.css';
import '@fontsource/jost/400.css';
import '@fontsource/jost/500.css';
import '../styles/global.css';

import jostBody from '@fontsource/jost/files/jost-latin-300-normal.woff2?url';
import cormorantDisplay from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-normal.woff2?url';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  breadcrumbs?: Crumb[];
  event?: boolean;
  article?: {
    headline: string;
    description: string;
    datePublished: string;
    author: string;
  };
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogImage = '/og-default.jpg',
  breadcrumbs = [],
  event = false,
  article,
} = Astro.props;

const site = 'https://www.sarksoulretreats.com';
const canonical = new URL(Astro.url.pathname.replace(/\/$/, '') || '/', site).href;
const ogImageUrl = new URL(ogImage, site).href;

const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: c.label,
          item: new URL(c.href, site).href,
        })),
      }
    : null;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preload" as="font" type="font/woff2" href={jostBody} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={cormorantDisplay} crossorigin />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sark Soul Island Retreats" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <Schema canonical={canonical} event={event} article={article} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
    {
      /* GA4 ships only when PUBLIC_GA4_ID is set in the build environment.
         Lightweight direct gtag include per SPEC section 10, loaded async. */
      import.meta.env.PUBLIC_GA4_ID && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}
          />
          <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA4_ID }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
    <slot name="head" />
  </head>
  <body>
    <a class="visually-hidden" href="#main">Skip to content</a>
    <Header />
    <p class="promo-banner">Early booking rate ends 31 July - <a class="promo-gold" href="/retreats-on-sark">limited places available</a></p>
    <main id="main">
      <slot />
    </main>
    <Footer />
    {/* Answer panel. The button opens a native details panel; the inline
        script below is the whole client, kept well inside the 15KB budget. */}
    <details class="chat" id="sark-chat">
      <summary class="chat-btn" aria-label="Ask a question about the retreat">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.4 8.4 0 0 1-9 8.4 9 9 0 0 1-3.8-.8L3 20l1-4.1a8.3 8.3 0 0 1-1-4A8.4 8.4 0 0 1 12 3.5a8.4 8.4 0 0 1 9 8Z" />
          <path d="M8 10.5h8M8 13.5h5" />
        </svg>
      </summary>
      <div class="chat-panel">
        <div class="chat-head">
          <strong>Ask us anything</strong>
          <span>Instant answers about the September retreat. Anything personal goes to Nadia.</span>
        </div>
        <div class="chat-log" id="chat-log" aria-live="polite">
          <p class="msg bot">Hello, and welcome to Sark Soul Island Retreats. Ask me anything about the September retreat, the island, or the journey over.</p>
        </div>
        <div class="chat-starters" id="chat-starters">
          <button type="button">When is the retreat and what does it cost?</button>
          <button type="button">I haven't done yoga in years, is that okay?</button>
          <button type="button">I'd be coming alone, is that okay?</button>
          <button type="button">How do I get to Sark?</button>
        </div>
        <form class="chat-form" id="chat-form">
          <input id="chat-input" type="text" maxlength="600" placeholder="Type your question" aria-label="Your question" autocomplete="off" required />
          <button class="chat-send" type="submit">Send</button>
        </form>
      </div>
    </details>
    <script is:inline>
      (function () {
        var log = document.getElementById('chat-log');
        var form = document.getElementById('chat-form');
        var input = document.getElementById('chat-input');
        var starters = document.getElementById('chat-starters');
        var root = document.getElementById('sark-chat');
        var messages = [];
        var busy = false;

        function esc(s) {
          return s.replace(/[&<>"]/g, function (c) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
          });
        }
        function linkify(s) {
          return s
            .replace(/https:\/\/[^\s)]+/g, function (u) {
              var clean = u.replace(/[.,]$/, '');
              return '<a href="' + clean + '">' + clean.replace(/^https:\/\/(www\.)?/, '') + '</a>';
            })
            .replace(/(^|\s)(\/retreats-on-sark)/g, '$1<a href="/retreats-on-sark">the booking page</a>');
        }
        function add(role, text) {
          var p = document.createElement('p');
          p.className = 'msg ' + role;
          p.innerHTML = linkify(esc(text));
          log.appendChild(p);
          log.scrollTop = log.scrollHeight;
          return p;
        }
        function send(q) {
          if (busy || !q) return;
          busy = true;
          starters.hidden = true;
          messages.push({ role: 'user', content: q });
          add('user', q);
          var wait = add('bot', '. . .');
          fetch('/api/chat', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ messages: messages, page: location.pathname }),
          })
            .then(function (r) { return r.json(); })
            .then(function (d) {
              var reply = d.reply || 'Something went astray. Email info@sarksoulretreats.com and we will reply quickly.';
              messages.push({ role: 'assistant', content: reply });
              wait.innerHTML = linkify(esc(reply));
            })
            .catch(function () {
              wait.textContent = 'Something went astray. Email info@sarksoulretreats.com and we will reply quickly.';
            })
            .finally(function () {
              busy = false;
              log.scrollTop = log.scrollHeight;
            });
        }
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          var q = input.value.trim();
          input.value = '';
          send(q);
        });
        starters.addEventListener('click', function (e) {
          if (e.target.tagName === 'BUTTON') send(e.target.textContent);
        });
        root.addEventListener('toggle', function () {
          if (root.open) input.focus();
        });
      })();
    </script>
  </body>
</html>
