# Cache policy. Files under /_astro carry a content hash in their name, so
# they can never change in place: cache them for a year, immutable. The
# un-hashed icons get a day, since they are occasionally edited in place.
# Everything else keeps Netlify's default ETag revalidation.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=86400

# The guide PDF is the email-capture reward. Keep it out of search results
# so the public Journal articles built from the same material get the
# ranking credit, and the PDF stays a reason to hand over an email.
/guides/*
  X-Robots-Tag: noindex

# The guide thank-you page exists as a conversion signal for Google Ads,
# not as a landing page, so it stays out of search results too.
/guide-thanks
  X-Robots-Tag: noindex
