# Cache policy. Files under /_astro carry a content hash in their name, so
# they can never change in place: cache them for a year, immutable. The
# un-hashed icons get a day, since they are occasionally edited in place.
# Everything else keeps Netlify's default ETag revalidation.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/icons/*
  Cache-Control: public, max-age=86400
