---
// Guide downloads band: the "Getting to Sark Guide signup" MailerLite form
// on a cream strip. Used on Home, /why-sark and the Getting to Sark guide
// page per spec section 10.

import MailerLiteForm from './MailerLiteForm.astro';
---

<section class="guide-signup">
  <div class="container">
    <span class="eyebrow">Free guide</span>
    <h2>Getting to Sark</h2>
    <p>
      Guests used to ask me the same things before they came, and I loved answering. So I gathered
      it all into this little guide: the ferry, the famous luggage system, what the first evening
      feels like.
    </p>
    <p class="guide-attribution">Nadia, founder and host</p>
    <MailerLiteForm
      formId="191498830146962835"
      shareUrl="https://preview.mailerlite.io/forms/2309024/191498830146962835/share"
      label="Get the Getting to Sark guide"
    />
    <p class="guide-smallprint">No spam, just island news now and then. Unsubscribe anytime.</p>
  </div>
</section>

<style>
  .guide-signup {
    background: var(--cream);
    padding-block: 4rem;
    text-align: center;
    margin-top: var(--space-section);
  }

  .guide-signup h2 {
    margin-block: 0.8rem 1rem;
  }

  .guide-signup p {
    max-width: 62ch;
    margin-inline: auto;
    margin-bottom: 1.8rem;
  }

  .guide-attribution {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 19px;
    color: var(--sage-dark);
    margin-top: -0.9rem;
  }

  .guide-smallprint {
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--sage-dark);
    margin-top: 1.2rem;
    margin-bottom: 0;
  }
</style>
