---
// FAQ: native details accordions, Cormorant summaries, zero JavaScript.
// Pass the same items array to BaseLayout's faqs prop so the FAQPage
// schema is generated from the identical content.

import type { FaqItem } from './Schema.astro';

interface Props {
  heading?: string;
  items: FaqItem[];
}

const { heading = 'Questions, answered', items } = Astro.props;
---

<section class="faq section">
  <div class="container-narrow">
    <span class="eyebrow">Before you ask</span>
    <h2>{heading}</h2>
    <div class="faq-list">
      {
        items.map((item) => (
          <details>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-list {
    margin-top: 1.5rem;
  }

  details {
    border-bottom: 1px solid var(--cream-deep);
  }

  summary {
    font-family: var(--font-display);
    font-size: clamp(19px, 2.2vw, 23px);
    font-weight: 500;
    color: var(--ink);
    padding: 1.1rem 2rem 1.1rem 0;
    cursor: pointer;
    list-style: none;
    position: relative;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '+';
    position: absolute;
    right: 0.2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 22px;
    color: var(--sage);
    transition: transform 0.2s ease;
  }

  details[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }

  details p {
    padding-bottom: 1.3rem;
    margin: 0;
    max-width: 62ch;
  }
</style>
